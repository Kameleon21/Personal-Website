---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../utils/date';
import { getReadingTime } from '../utils/readingTime';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  image?: string;
}

const { title, description, pubDate, author, image } = Astro.props;
const { Content, headings } = await Astro.props.post.render();

// Get reading time
const readingTime = getReadingTime(await Astro.props.post.body);
---

<Layout title={title} description={description}>
  <Header />
  <div class="relative">
    <TableOfContents headings={headings} />
    <article class="max-w-3xl mx-auto px-4 py-20">
      {image && (
        <img 
          src={image} 
          alt={title} 
          class="w-full h-[400px] object-cover rounded-2xl mb-8"
        />
      )}
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <div class="flex flex-wrap gap-4 text-gray-600 mb-8">
        <span>{author}</span>
        <span>•</span>
        <time>{formatDate(pubDate)}</time>
        <span>•</span>
        <span>{readingTime} min read</span>
      </div>
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </article>
  </div>
</Layout>

<style>
  /* Add smooth scrolling for heading navigation */
  html {
    scroll-behavior: smooth;
  }

  /* Style the headings with anchor links */
  :global(.prose h2, .prose h3) {
    scroll-margin-top: 100px;
  }

  :global(.prose h2:hover .anchor,
  .prose h3:hover .anchor) {
    opacity: 1;
  }

  :global(.anchor) {
    opacity: 0;
    transition: opacity 0.2s;
    margin-left: 0.5rem;
  }
</style> 