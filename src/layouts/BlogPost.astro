---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../utils/date';
import { getReadingTime } from '../utils/readingTime';
import '../styles/blog-post.css';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  post: any;
}

const { title, description, pubDate, author, post } = Astro.props;
const { Content, headings } = await post.render();
const readingTime = getReadingTime(post.body);
---

<Layout title={title} description={description}>
  <ReadingProgress />
  <Header />

  <div class="bg-brutal-black min-h-screen">
    <div class="max-w-7xl mx-auto px-4 py-20">
      <div class="flex gap-12">
        <!-- Table of Contents - Left Sidebar -->
        <TableOfContents headings={headings} />

        <!-- Main Content -->
        <article class="flex-1 max-w-3xl mx-auto xl:mx-0">
          <!-- Article Header -->
          <header class="mb-12">
            <h1 class="text-3xl lg:text-5xl font-bold mb-6 text-brutal-white uppercase leading-tight tracking-tight">
              {title}
            </h1>
            <div class="flex flex-wrap items-center gap-4 text-brutal-grey text-xs uppercase tracking-widest">
              <span class="text-brutal-white">{author}</span>
              <span class="text-brutal-rule">|</span>
              <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
              <span class="text-brutal-rule">|</span>
              <span>{readingTime} min read</span>
            </div>
            <div class="brutal-hr mt-6"></div>
          </header>

          <!-- Article Content -->
          <div class="prose prose-lg prose-brutal max-w-none
            prose-headings:font-mono prose-headings:font-bold prose-headings:text-brutal-white prose-headings:uppercase prose-headings:tracking-tight
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:pb-2 prose-h2:border-b prose-h2:border-brutal-rule
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-4
            prose-p:text-brutal-white/80 prose-p:leading-relaxed
            prose-a:text-brutal-red prose-a:no-underline hover:prose-a:underline
            prose-strong:text-brutal-white
            prose-code:text-brutal-red prose-code:bg-[#111] prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-sm prose-code:border prose-code:border-brutal-rule
            prose-pre:bg-[#111] prose-pre:border prose-pre:border-brutal-rule
            prose-blockquote:border-l-brutal-red prose-blockquote:bg-[#111]/50 prose-blockquote:py-1 prose-blockquote:px-6
            prose-ul:text-brutal-white/80 prose-ol:text-brutal-white/80
            prose-li:marker:text-brutal-red
            prose-hr:border-brutal-rule
          ">
            <Content />
          </div>
        </article>

        <!-- Spacer for right side balance on xl screens -->
        <div class="hidden xl:block w-60"></div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<script src="../scripts/copy-code.js"></script>
