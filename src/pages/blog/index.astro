---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import { getReadingTime } from '../../utils/readingTime';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog - Kamil Rogozinski" description="Read my latest blog posts about web development, design, and technology.">
  <Header />
  <main class="min-h-screen bg-brutal-black pt-24 pb-20 px-8">
    <div class="container mx-auto max-w-5xl">
      <header class="mb-16">
        <div class="text-brutal-grey text-xs uppercase tracking-widest mb-4">/blog</div>
        <h1 class="text-4xl md:text-5xl font-bold text-brutal-white uppercase tracking-tight mb-4">Blog</h1>
        <p class="text-brutal-grey text-sm">Thoughts on software development, design, and technology.</p>
      </header>

      {sortedPosts.length > 0 ? (
        <div class="space-y-6">
          {sortedPosts.map((post) => (
            <article class="brutal-card group">
              <a href={`/Personal-Website/blog/${post.slug}`} class="block">
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags?.map((tag: string) => (
                    <span class="brutal-tag">{tag}</span>
                  ))}
                </div>

                <h2 class="text-xl lg:text-2xl font-bold text-brutal-white uppercase tracking-tight mb-3 group-hover:text-brutal-red transition-colors">
                  {post.data.title}
                </h2>

                <p class="text-brutal-grey text-sm mb-6 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>

                <div class="brutal-hr mb-4"></div>

                <div class="flex flex-wrap items-center gap-4 text-xs text-brutal-grey uppercase tracking-widest">
                  <span>{post.data.author}</span>
                  <span class="text-brutal-rule">|</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  <span class="text-brutal-rule">|</span>
                  <span>{getReadingTime(post.body)} min read</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20">
          <div class="text-center max-w-2xl">
            <h2 class="text-2xl font-bold text-brutal-white uppercase tracking-tight mb-4">No Posts Yet</h2>
            <p class="text-brutal-grey text-sm">
              Working on some exciting blog posts about web development, design, and technology.
            </p>
          </div>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
