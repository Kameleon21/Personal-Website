---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import { Image } from 'astro:assets';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog - Kamil Rogozinski" description="Read my latest blog posts about web development, design, and technology.">
  <Header />
  <main class="min-h-screen bg-gray-50 pt-24 px-8">
    <div class="container mx-auto max-w-6xl">
      <h1 class="text-5xl font-bold mb-16">Blog</h1>
      
      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <article class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
              {post.data.image && (
                <div class="aspect-video overflow-hidden">
                  <Image 
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    decoding="async"
                    width={800}
                    height={450}
                  />
                </div>
              )}
              <div class="p-6">
                <h2 class="text-2xl font-bold mb-2 text-gray-800 line-clamp-2">
                  <a href={`/Personal-Website/blog/${post.slug}`} class="hover:text-indigo-600 transition-colors">
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 mb-4 line-clamp-3">{post.data.description}</p>
                <div class="flex justify-between items-center text-sm text-gray-500 mb-4">
                  <span>{post.data.author}</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                </div>
                {post.data.tags && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs bg-indigo-100 text-indigo-700 rounded-full font-medium">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20">
          <div class="text-center max-w-2xl">
            <h2 class="text-3xl font-bold text-gray-800 mb-4">No Posts Yet</h2>
            <p class="text-xl text-gray-600">
              I'm working on some exciting blog posts about web development, design, and technology. 
              Stay tuned for insightful content coming your way!
            </p>
          </div>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout> 