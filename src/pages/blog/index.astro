---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import { getReadingTime } from '../../utils/readingTime';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog - Kamil Rogozinski" description="Read my latest blog posts about web development, design, and technology.">
  <Header />
  <main class="min-h-screen bg-primary pt-24 pb-20 px-8">
    <div class="container mx-auto max-w-5xl">
      <header class="mb-16">
        <h1 class="text-5xl font-bold text-text-primary mb-4">Blog</h1>
        <p class="text-text-secondary text-lg">Thoughts on software development, design, and technology.</p>
      </header>

      {sortedPosts.length > 0 ? (
        <div class="space-y-8">
          {sortedPosts.map((post) => (
            <article class="group bg-secondary rounded-2xl border border-border p-8 hover-glow transition-all duration-300">
              <a href={`/Personal-Website/blog/${post.slug}`} class="block">
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags?.map((tag: string) => (
                    <span class="px-3 py-1 text-xs bg-accent/10 text-accent rounded-md font-medium border border-accent/20">
                      {tag}
                    </span>
                  ))}
                </div>

                <h2 class="text-2xl lg:text-3xl font-bold text-text-primary mb-3 group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>

                <p class="text-text-secondary mb-6 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>

                <div class="flex flex-wrap items-center gap-4 text-sm text-text-muted">
                  <span>{post.data.author}</span>
                  <span class="text-border">|</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  <span class="text-border">|</span>
                  <span>{getReadingTime(post.body)} min read</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20">
          <div class="text-center max-w-2xl">
            <h2 class="text-3xl font-bold text-text-primary mb-4">No Posts Yet</h2>
            <p class="text-xl text-text-secondary">
              I'm working on some exciting blog posts about web development, design, and technology.
              Stay tuned for insightful content coming your way!
            </p>
          </div>
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
