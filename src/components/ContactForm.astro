---
interface Props {
  activeTab: 'get-in-touch' | 'work-together';
}

const { activeTab } = Astro.props;
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="contact-form"
  class="needs-validation"
  data-astro-reload
  novalidate
  aria-label="Contact form">
  <input type="hidden" name="access_key" value="05b550d2-4a55-48ac-a936-b35068dbd9d6" />
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" aria-hidden="true" tabindex="-1" />
  
  <div class="mb-6">
    <input
      type="text"
      placeholder="Your Name"
      required
      class="w-full px-6 py-4 bg-white rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-300 outline-none"
      name="name"
      id="name"
      aria-label="Your name"
      aria-required="true"
      aria-describedby="name-error"
    />
    <div id="name-error" class="empty-feedback invalid-feedback text-red-500 text-sm mt-1" role="alert">
      Please provide your name.
    </div>
  </div>

  <div class="mb-6">
    <input
      type="email"
      placeholder="Your Email"
      required
      class="w-full px-6 py-4 bg-white rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-300 outline-none"
      name="email"
      id="email"
      aria-label="Your email address"
      aria-required="true"
      aria-describedby="email-error email-invalid-error"
    />
    <div id="email-error" class="empty-feedback text-red-500 text-sm mt-1" role="alert">
      Please provide your email address.
    </div>
    <div id="email-invalid-error" class="invalid-feedback text-red-500 text-sm mt-1" role="alert">
      Please provide a valid email address.
    </div>
  </div>

  <div class="mb-6">
    <textarea
      name="message"
      required
      placeholder={activeTab === 'get-in-touch' 
        ? "I'd like to discuss..." 
        : "I have a project that I'd like to discuss. Here are some details..."}
      class="w-full px-6 py-4 bg-white rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-all duration-300 outline-none h-48 resize-none"
      id="message"
      aria-label="Your message"
      aria-required="true"
      aria-describedby="message-error"
    ></textarea>
    <div id="message-error" class="empty-feedback invalid-feedback text-red-500 text-sm mt-1" role="alert">
      Please enter your message.
    </div>
  </div>

  <button
    type="submit"
    class="w-full bg-blue-500 text-white font-semibold py-4 px-8 rounded-xl hover:bg-blue-600 transition-all duration-300 transform hover:scale-[1.02]"
    aria-label="Send message"
  >
    Send Message
  </button>

  <div id="form-result" class="mt-4 text-center hidden" role="status" aria-live="polite">
    <div class="success-message bg-green-100 text-green-700 p-4 rounded-xl">
      Thank you for your message! I'll get back to you within 24 hours.
    </div>
  </div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #ef4444;
  }
</style> 