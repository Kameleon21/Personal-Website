---
interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<a
  href={`/Personal-Website/blog/${slug}`}
  class="brutal-card flex flex-col group block"
>
  <h3 class="text-lg font-bold mb-3 text-brutal-white uppercase tracking-tight group-hover:text-brutal-red transition-colors">
    {title}
  </h3>
  <p class="text-brutal-grey text-sm mb-4 flex-grow leading-relaxed">
    {description}
  </p>
  <div class="text-xs uppercase tracking-widest text-brutal-grey group-hover:text-brutal-red transition-colors">
    Read more &rarr;
  </div>
</a>
