---
interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<a 
  href={`/blog/${slug}`}
  class="bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl transition-all duration-300 flex flex-col group"
>
  <h3 class="text-2xl font-bold mb-4 group-hover:text-blue-600 transition-colors">
    {title}
  </h3>
  <p class="text-gray-600 mb-4 flex-grow">
    {description}
  </p>
  <div class="flex items-center text-blue-500 group-hover:text-blue-600">
    Read more 
    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </div>
</a> 