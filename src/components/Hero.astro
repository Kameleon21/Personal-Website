---
---

<section class="min-h-screen bg-brutal-black relative flex items-center px-8">
  <div class="container mx-auto relative z-10">
    <!-- Giant title -->
    <h1 class="text-[clamp(3rem,10vw,8rem)] font-bold leading-[0.9] uppercase tracking-tighter mb-8">
      <span class="text-brutal-white">Full Stack</span><br>
      <span class="text-brutal-red">Developer</span><span class="cursor-blink"></span>
    </h1>

    <!-- Metadata line -->
    <div class="flex flex-wrap gap-6 text-xs uppercase tracking-widest text-brutal-grey mb-12 border-t border-brutal-rule pt-6">
      <span>Portfolio &mdash; 2024</span>
      <span class="text-brutal-rule">|</span>
      <span>Based in Ireland</span>
      <span class="text-brutal-rule">|</span>
      <span class="flex items-center gap-2"><span class="status-dot"></span> Available for work</span>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-4">
      <a
        href={`${import.meta.env.BASE_URL}#contact`}
        class="px-8 py-3 bg-brutal-red text-brutal-black text-xs uppercase tracking-widest font-bold hover:bg-brutal-white transition-colors"
      >
        Get in touch
      </a>
      <a
        href={`${import.meta.env.BASE_URL}#work`}
        class="px-8 py-3 border border-brutal-rule text-brutal-grey text-xs uppercase tracking-widest font-bold hover:border-brutal-red hover:text-brutal-red transition-colors"
      >
        View work
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-brutal-grey text-xs uppercase tracking-widest hidden lg:block">
      <span class="inline-block motion-safe:animate-bounce">&darr;</span> Scroll
    </div>
  </div>
</section>
