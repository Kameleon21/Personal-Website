---
---

<nav class="fixed top-0 w-full bg-white/95 backdrop-blur-sm z-[100] py-4 px-8 shadow-sm">
  <div class="container mx-auto flex justify-between items-center relative">
    <a href="/" class="text-2xl font-bold text-gray-800 relative z-[102]">Portfolio</a>
    
    <!-- Desktop Navigation -->
    <div class="hidden lg:flex gap-8">
      <a href="/#about" class="text-xl text-gray-600 hover:text-indigo-600 transition-colors">About</a>
      <a href="/#work" class="text-xl text-gray-600 hover:text-indigo-600 transition-colors">Work</a>
      <a href="/#blog" class="text-xl text-gray-600 hover:text-indigo-600 transition-colors">Blog</a>
      <a href="/#contact" class="text-xl text-gray-600 hover:text-indigo-600 transition-colors">Contact</a>
    </div>

    <!-- Hamburger Menu Button -->
    <button 
      id="hamburger"
      class="lg:hidden flex flex-col justify-center items-center w-12 h-12 relative focus:outline-none z-[102] gap-1.5 p-2.5 rounded-lg hover:bg-gray-100 transition-colors"
      aria-label="Menu"
      aria-expanded="false"
    >
      <div class="w-6 h-0.5 bg-gray-800"></div>
      <div class="w-6 h-0.5 bg-gray-800"></div>
      <div class="w-6 h-0.5 bg-gray-800"></div>
    </button>

    <!-- Mobile Navigation Menu -->
    <div 
      id="mobile-nav"
      class="fixed left-0 right-0 top-[72px] bg-white shadow-lg z-[101] transform translate-y-[-100%] lg:hidden overflow-hidden"
    >
      <div class="container mx-auto">
        <div class="flex flex-col px-8">
          <a href="/#about" 
            class="py-4 text-lg text-gray-800 hover:bg-gray-50 hover:text-indigo-600 transition-all font-medium border-b border-gray-100" 
            style="--index: 0">
            About
          </a>
          <a href="/#work" 
            class="py-4 text-lg text-gray-800 hover:bg-gray-50 hover:text-indigo-600 transition-all font-medium border-b border-gray-100" 
            style="--index: 1">
            Work
          </a>
          <a href="/#blog" 
            class="py-4 text-lg text-gray-800 hover:bg-gray-50 hover:text-indigo-600 transition-all font-medium border-b border-gray-100" 
            style="--index: 2">
            Blog
          </a>
          <a href="/#contact" 
            class="py-4 text-lg text-gray-800 hover:bg-gray-50 hover:text-indigo-600 transition-all font-medium border-b border-gray-100" 
            style="--index: 3">
            Contact
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  import { initMobileMenu } from '../scripts/header.js';
  document.addEventListener('DOMContentLoaded', () => {
    initMobileMenu();
  });
</script> 