---
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';
import { getReadingTime } from '../utils/readingTime';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section id="blog" class="bg-brutal-black py-20 px-4 md:px-8">
  <div class="section-scan" aria-hidden="true"></div>
  <div class="container mx-auto max-w-6xl">
    <!-- Section counter -->
    <div class="text-brutal-grey text-xs uppercase tracking-widest mb-4 reveal">/03</div>
    <div class="flex justify-between items-end mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-brutal-white uppercase tracking-tight reveal" data-delay="1">
        Blog
      </h2>
      <a
        href="/Personal-Website/blog"
        class="text-xs uppercase tracking-widest text-brutal-grey hover:text-brutal-red transition-colors reveal" data-delay="1"
      >
        All posts &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {sortedPosts.slice(0, 2).map((post) => (
        <article class="brutal-card reveal">
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags?.slice(0, 2).map((tag: string) => (
              <span class="brutal-tag">{tag}</span>
            ))}
          </div>

          <h3 class="text-lg font-bold text-brutal-white uppercase tracking-tight mb-3">
            <a href={`/Personal-Website/blog/${post.slug}`} class="hover:text-brutal-red transition-colors">
              {post.data.title}
            </a>
          </h3>

          <p class="text-brutal-grey text-sm mb-4 leading-relaxed line-clamp-2">{post.data.description}</p>

          <div class="brutal-hr mb-4"></div>

          <div class="flex justify-between items-center text-xs text-brutal-grey uppercase tracking-widest">
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <span>{getReadingTime(post.body)} min read</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
