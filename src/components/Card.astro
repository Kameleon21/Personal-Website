---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import personalWebsite from '../assets/Personal-Website.jpeg';
import barberShop from '../assets/A-Class-Barbers.jpeg';
import ceEquipmentSolutions from '../assets/ce-equipment-solutions.png';
import groupDinnerPicker from '../assets/Group-Picker.png';
import iso9001 from '../assets/iso9001.png';

const images: Record<string, ImageMetadata> = {
  'Personal-Website.jpeg': personalWebsite,
  'A-Class-Barbers.jpeg': barberShop,
  'CE-Equipment-Solutions.jpeg': ceEquipmentSolutions,
  'Group-Picker.png': groupDinnerPicker,
  'ce-equipment-solutions.png': ceEquipmentSolutions,
  'group-picker.png': groupDinnerPicker,
  'group-dinner-picker.png': groupDinnerPicker,
  'ARC-Management-Systems.jpeg': iso9001,
  'iso9001.png': iso9001
};

interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  githubLink: string;
  technologies?: string[];
}

const { title, description, image, link, githubLink, technologies } = Astro.props;
const imageFileName = image.split('/').pop() || '';
const imageSource = images[imageFileName];
const hasValidImage = imageSource !== undefined;
---

<div class="bg-white rounded-3xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 transform translate-y-10 slide-up h-full flex flex-col motion-safe:hover:-translate-y-3 motion-safe:hover:scale-[1.02] motion-safe:focus-within:-translate-y-3 motion-safe:focus-within:scale-[1.02]">
  <div class="aspect-video rounded-2xl overflow-hidden mb-6 bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center">
    {hasValidImage ? (
      <Image 
        src={imageSource}
        width={800}
        height={450}
        alt={title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="text-white text-center p-8">
        <Icon name="mdi:web" class="w-16 h-16 mx-auto mb-4 opacity-80" />
        <p class="text-lg font-semibold opacity-90">{title}</p>
        <p class="text-sm opacity-70 mt-2">Project Screenshot Coming Soon</p>
      </div>
    )}
  </div>
  
  <div class="flex-grow flex flex-col">
    <h3 class="text-2xl font-bold mb-4 text-gray-900">{title}</h3>
    <p class="text-gray-600 mb-4 flex-grow">{description}</p>
    
    {technologies && technologies.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {technologies.map((tech) => (
          <span class="px-3 py-1 text-sm bg-blue-100 text-blue-700 rounded-full font-medium">
            {tech}
          </span>
        ))}
      </div>
    )}
  </div>
  
  <div class="flex gap-4 justify-center mt-auto">
    {githubLink && (
      <a 
        href={githubLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center p-2 rounded-full text-gray-700 hover:text-gray-900 hover:bg-gray-100 transition-all cursor-pointer"
        aria-label="View GitHub Repository"
      >
        <Icon name="mdi:github" class="w-6 h-6" />
      </a>
    )}
    {link && (
      <a 
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center p-2 rounded-full text-gray-700 hover:text-gray-900 hover:bg-gray-100 transition-all cursor-pointer"
        aria-label="View Live Project"
      >
        <Icon name="mdi:web" class="w-6 h-6" />
      </a>
    )}
  </div>
</div> 
