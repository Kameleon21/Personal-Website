---
interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
}

const { title, description, image, link } = Astro.props;
---

<div class="bg-white rounded-3xl p-6 shadow-lg hover:shadow-xl transition-all duration-300 opacity-0 transform translate-y-10 slide-up">
  <div class="aspect-video rounded-2xl overflow-hidden mb-6">
    <img 
      src={image} 
      alt={title}
      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
    />
  </div>
  
  <h3 class="text-2xl font-bold mb-4">{title}</h3>
  <p class="text-gray-600 mb-6">{description}</p>
  
  <a 
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center text-blue-500 hover:text-blue-600 transition-colors"
  >
    View Project
    <svg class="w-5 h-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
    </svg>
  </a>
</div> 