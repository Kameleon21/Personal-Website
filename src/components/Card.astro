---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import personalWebsite from '../assets/Personal-Website.jpeg';
import barberShop from '../assets/A-Class-Barbers.jpeg';
import ceEquipmentSolutions from '../assets/ce-equipment-solutions.png';
import groupDinnerPicker from '../assets/Group-Picker.png';
import iso9001 from '../assets/iso9001.png';

const images: Record<string, ImageMetadata> = {
  'Personal-Website.jpeg': personalWebsite,
  'A-Class-Barbers.jpeg': barberShop,
  'CE-Equipment-Solutions.jpeg': ceEquipmentSolutions,
  'Group-Picker.png': groupDinnerPicker,
  'ce-equipment-solutions.png': ceEquipmentSolutions,
  'group-picker.png': groupDinnerPicker,
  'group-dinner-picker.png': groupDinnerPicker,
  'ARC-Management-Systems.jpeg': iso9001,
  'iso9001.png': iso9001
};

interface Props {
  title: string;
  description: string;
  image: string;
  link: string;
  githubLink: string;
  technologies?: string[];
}

const { title, description, image, link, githubLink, technologies } = Astro.props;
const imageFileName = image.split('/').pop() || '';
const imageSource = images[imageFileName];
const hasValidImage = imageSource !== undefined;
---

<div class="bg-tertiary rounded-2xl p-6 border border-border hover-glow transition-all duration-300 opacity-0 transform translate-y-10 slide-up h-full flex flex-col motion-safe:hover:-translate-y-2 motion-safe:hover:scale-[1.01] motion-safe:focus-within:-translate-y-2 motion-safe:focus-within:scale-[1.01]">
  <div class="aspect-video rounded-xl overflow-hidden mb-6 bg-primary flex items-center justify-center border border-border">
    {hasValidImage ? (
      <Image
        src={imageSource}
        width={800}
        height={450}
        alt={title}
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
      />
    ) : (
      <div class="text-text-muted text-center p-8">
        <Icon name="mdi:web" class="w-16 h-16 mx-auto mb-4 opacity-60" />
        <p class="text-lg font-semibold text-text-secondary">{title}</p>
        <p class="text-sm opacity-70 mt-2">Project Screenshot Coming Soon</p>
      </div>
    )}
  </div>

  <div class="flex-grow flex flex-col">
    <h3 class="text-2xl font-bold mb-4 text-text-primary">{title}</h3>
    <p class="text-text-secondary mb-4 flex-grow leading-relaxed">{description}</p>

    {technologies && technologies.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {technologies.map((tech) => (
          <span class="px-3 py-1 text-sm bg-accent/10 text-accent rounded-md font-medium border border-accent/20">
            {tech}
          </span>
        ))}
      </div>
    )}
  </div>

  <div class="flex gap-4 justify-center mt-auto pt-4 border-t border-border">
    {githubLink && (
      <a
        href={githubLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center p-2 rounded-lg text-text-muted hover:text-accent hover:bg-accent/10 transition-all cursor-pointer"
        aria-label="View GitHub Repository"
      >
        <Icon name="mdi:github" class="w-6 h-6" />
      </a>
    )}
    {link && (
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center p-2 rounded-lg text-text-muted hover:text-accent hover:bg-accent/10 transition-all cursor-pointer"
        aria-label="View Live Project"
      >
        <Icon name="mdi:web" class="w-6 h-6" />
      </a>
    )}
  </div>
</div>
