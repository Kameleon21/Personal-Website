---
interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;
---

<nav class="toc hidden lg:block">
  <div class="sticky top-24">
    <h2 class="text-lg font-semibold mb-4">Table of Contents</h2>
    <ul class="space-y-2">
      {
        headings.map((heading) => (
          <li class={`${heading.depth === 2 ? '' : 'ml-4'}`}>
            <a
              href={`#${heading.slug}`}
              class={`text-gray-600 hover:text-blue-600 transition-colors ${
                heading.depth === 2 ? 'font-medium' : ''
              }`}
            >
              {heading.text}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .toc {
    width: 240px;
    position: fixed;
    right: calc((100vw - 1152px) / 2);
    max-height: calc(100vh - 200px);
    overflow-y: auto;
  }

  @media (max-width: 1400px) {
    .toc {
      right: 1rem;
    }
  }
</style> 