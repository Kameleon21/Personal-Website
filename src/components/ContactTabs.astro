---
interface Props {
  activeTab: 'get-in-touch' | 'work-together';
}

const { activeTab } = Astro.props;
---

<div class="flex gap-0 mb-8 border-b border-brutal-rule" role="tablist" aria-label="Contact options">
  <button
    class={`flex-1 py-3 text-xs uppercase tracking-widest text-center transition-colors contact-tab ${activeTab === 'get-in-touch' ? 'active' : ''}`}
    data-tab="get-in-touch"
    role="tab"
    aria-selected={activeTab === 'get-in-touch'}
    aria-controls="contact-form"
    id="tab-get-in-touch">
    Get in Touch
  </button>
  <button
    class={`flex-1 py-3 text-xs uppercase tracking-widest text-center transition-colors contact-tab ${activeTab === 'work-together' ? 'active' : ''}`}
    data-tab="work-together"
    role="tab"
    aria-selected={activeTab === 'work-together'}
    aria-controls="contact-form"
    id="tab-work-together">
    Work Together
  </button>
</div>

<style>
  .contact-tab {
    color: #888;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }

  .contact-tab:hover {
    color: #F5F0EB;
  }

  .contact-tab.active {
    color: #FF2D00;
    border-bottom-color: #FF2D00;
  }
</style>
