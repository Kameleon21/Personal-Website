---
interface Props {
  activeTab: 'get-in-touch' | 'work-together';
}

const { activeTab } = Astro.props;
---

<div class="flex gap-4 mb-8" role="tablist" aria-label="Contact options">
  <button
    class={`flex-1 py-3 px-6 rounded-lg transition-all duration-300 text-center contact-tab ${activeTab === 'get-in-touch' ? 'active' : ''}`}
    data-tab="get-in-touch"
    role="tab"
    aria-selected={activeTab === 'get-in-touch'}
    aria-controls="contact-form"
    id="tab-get-in-touch">
    Get in Touch
  </button>
  <button
    class={`flex-1 py-3 px-6 rounded-lg transition-all duration-300 text-center contact-tab ${activeTab === 'work-together' ? 'active' : ''}`}
    data-tab="work-together"
    role="tab"
    aria-selected={activeTab === 'work-together'}
    aria-controls="contact-form"
    id="tab-work-together">
    Work Together
  </button>
</div>

<style>
  .contact-tab {
    background-color: #141416;
    color: #71717A;
    border: 1px solid #27272A;
  }

  .contact-tab:hover {
    color: #A1A1AA;
    border-color: rgba(45, 212, 191, 0.3);
  }

  .contact-tab.active {
    background-color: #2DD4BF;
    color: #0A0A0B;
    border-color: #2DD4BF;
  }
</style>
