---
import ContactForm from './ContactForm.astro';
import ContactTabs from './ContactTabs.astro';

interface Props {
  title?: string;
}

const { title = "Get in Touch" } = Astro.props;
---

<section id="contact" class="min-h-screen bg-white py-20 px-8">
  <div class="container mx-auto max-w-3xl">
    <h2 class="text-5xl font-bold mb-16 opacity-0 transform translate-y-10 transition-all duration-700 ease-out slide-up">
      {title}
    </h2>

    <div class="bg-gray-50 rounded-3xl p-8 md:p-12 shadow-lg opacity-0 transform translate-y-10 transition-all duration-700 ease-out slide-up">
      <ContactTabs activeTab="get-in-touch" />
      <ContactForm activeTab="get-in-touch" />
    </div>
  </div>
</section>

<script>
  import { initContactForm } from '../scripts/contact-form';
  
  // Initialize form functionality when the DOM is loaded
  document.addEventListener("DOMContentLoaded", initContactForm);
</script> 